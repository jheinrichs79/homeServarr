# =============================================================
# DO NOT MAKE CHANGES TO THIS FILE
# =============================================================
# Each time you sync with GitHub, this file will be 
# overwritten with the version in the repository.
#
# Rename this file to  .env  and remove this header completely. 
# That way, when you sync with GitHub, your changes 
# will not be overwritten.
# =============================================================

# ----------------------------------------------------------------------------------------------
# Copy this file to .env in the same folder.
# Change all configurations like passwords and secrets.
# Delete from line 16 to line 1 and save.
# ----------------------------------------------------------------------------------------------
# ==============================================================================================
#  Jared Heinrichs's homeServarr docker compose config file
#
#  This single file is used for all modules
#
#    * managementTools                          Any App that allows you to manage the server/network
#    * productivity                             Any App that You can Draw or Write In
#    * selfhost                                 Any app that isn't about drawing / productivity
#    * servarrStack                             The complete setup including VPN Kill switch
#    * testContainers                           This is where you put all your test "stuff"
#
#  Any line that has #<-- !!!!!!!!!!!!!! you most likely will or should need to change
#
#  This file assumes 
#       The server is named "homeservarr"
#       The username is "homeservarr"       
#
# ==============================================================================================


# -----------------------------------------------------------------------------------
# GLOBAL SETTINGS
# -----------------------------------------------------------------------------------

# Server and Time
SERVERNAME="homeservarr"
TZ=Etc/UTC 
TZDISPLAY=America/Winnipeg #<-- !!!!!!!!!!!!!!

# Folders
VOL_BASE=/home/homeservarr/docker
VOL_MEDIA=/home/homeservarr/media
VOL_DOWNLOADS=/home/homeservarr/downloads
VOL_SHARED=/home/homeservarr/shared

# Credentials
PASSWORD=Password@1234 #<-- !!!!!!!!!!!!!!
HOMARR_SECRET=c860916024f334bc822feb6bb62919a13185529291ed3c95f08a576ebed1cead #<-- !!!!!!!!!!!!!!

# Database Info
DB_USERNAME=db_User
DB_DATABASE_NAME=dbType_applicationName #example: postgres_piHole


# -----------------------------------------------------------------------------------
# manageemntTools
# -----------------------------------------------------------------------------------




# -----------------------------------------------------------------------------------
# productivity
# -----------------------------------------------------------------------------------




# -----------------------------------------------------------------------------------
# selfhost
# -----------------------------------------------------------------------------------
SPEEDTEST_NAME="homeServarr Speedtest"
SYNCTHING_NAME="homeServarr"



# -----------------------------------------------------------------------------------
# servarrStack
# -----------------------------------------------------------------------------------
#
#   NORDVPN - Pick closest server
#       https://github.com/qdm12/gluetun-wiki/blob/main/setup/servers.md#update-the-vpn-servers-list
#
#   JELLYFIN SERVER - Setup
#       On first start, you will need to use this URL
#       http://homeservarr.home.local:2351/web/index.html#!/wizardstart.html
#
# -----------------------------------------------------------------------------------
#NORDVPN
VPNPROVIDER=nordvpn
OPENVPNUSER=REPLACE_NORDVPNUSER
OPENVPNPASSWORD=REPLACE_NORDVPNPASSWORD
SERVER_HOSTNAMES="ca1438.nordvpn.com"

#JELLYFIN
JELLYFINSERVER="http://homeservarr.home.local" # Change the next line to whatever you have setup the server name to be. 




